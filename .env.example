# Copy to .env.local and fill from Supabase → Project Settings → API.
# The two VITE_ vars are the only thing the app itself needs.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-PUBLISHABLE-OR-ANON-KEY

# Only needed by scripts/import-csv.ts (bulk history import from a CSV).
# The service-role/secret key bypasses row-level security — never expose it to
# the frontend or commit it.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
# Optional: which baby record to import into (only needed if you have >1).
CHILD_ID=UUID-FROM-children-TABLE
